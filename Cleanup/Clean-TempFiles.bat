REM DELETE TEMP FILES
cd /D %temp%
for /d %%D in (*) do rd /s /q "%%D"
del /f /q *

echo.
echo -----------------------------------------------------------------
echo ----------------------- Script completed! -----------------------
echo -----------------------------------------------------------------
pause
exit

